BOT_TOKEN=your_telegram_bot_token_here

# Telegram ID администраторов через запятую.
# Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

DATA_DIR=data

# Если Telegram API не открывается напрямую, укажите локальный прокси.
# Пример для Clash/V2Ray: TELEGRAM_PROXY_URL=http://127.0.0.1:10809
TELEGRAM_PROXY_URL=

# Для локального запуска обычно polling.
# Для Render нужен webhook.
BOT_MODE=polling
WEBHOOK_BASE_URL=
WEBHOOK_HOSTNAME=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
PORT=8080
